{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "# ",
          "foreground": "#CECE04",
          "type": "root",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none"
          },
          "template": "{{ .UserName }}@{{ .HostName }} ",
          "type": "session",
          "style": "plain"
        },
        {
          "properties": {
            "cache_duration": "none",
            "style": "agnoster_short"
          },
          "template": "{{ .Path }} ",
          "foreground": "#7B68EE",
          "type": "path",
          "style": "plain"
        },
        {
          "properties": {
            "branch_icon": "",
            "cache_duration": "none",
            "fetch_upstream_icon": false
          },
          "template": "HEAD:{{ .UpstreamIcon }}{{ .HEAD }} ",
          "foreground": "#48D1CC",
          "type": "git",
          "style": "plain"
        },
        {
          "properties": {
            "always_enabled": true,
            "cache_duration": "none"
          },
          "template": "<#66CDAA>❯</><#76EEC6>❯</><foreground>❯</> ",
          "foreground": "#7FFFD4",
          "type": "status",
          "style": "plain",
          "foreground_templates": [
            "{{ if gt .Code 0 }}#E84855{{ end }}"
          ]
        }
      ]
    }
  ],
  "version": 3
}
